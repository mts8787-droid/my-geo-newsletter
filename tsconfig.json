{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM"],
    "jsx": "preserve",

    "allowJs": true,
    "checkJs": true,
    "noEmit": true,

    "strict": false,
    "noImplicitAny": false,
    "strictNullChecks": false,

    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,

    "isolatedModules": true,
    "verbatimModuleSyntax": false
  },
  "include": [
    "lib/**/*.js",
    "routes/**/*.js",
    "server.js",
    "src/shared/insightAgent.js",
    "src/shared/insightPrompts.js",
    "src/excelUtils.js"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "dist-*",
    "**/*.test.js"
  ]
}
